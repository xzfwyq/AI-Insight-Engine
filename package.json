{
  "name": "ai-insight-engine",
  "version": "0.1.0",
  "description": "AI 舆情分析日报系统",
  "type": "module",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "pipeline": "node scripts/run-pipeline.mjs",
    "fetch": "node scripts/run-pipeline.mjs --only-fetch",
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "lint": "eslint src scripts tests --ext .js,.mjs,.vue",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{js,mjs,vue,json,md}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5",
    "p-limit": "^5.0.0",
    "rss-parser": "^3.13.0",
    "undici": "^7.28.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.27.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "prettier": "^3.3.3",
    "vitest": "^2.0.5"
  },
  "lint-staged": {
    "*.{js,mjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

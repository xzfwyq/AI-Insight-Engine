# API Key (必填,用于 AI Pipeline 抽取和聚合)
# 支持原生 Anthropic API 或 Anthropic 兼容协议代理(GLM/Kimi/DeepSeek 等)
ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# 可选: 自定义 Base URL(用于兼容协议代理)
# 例如通过 Anthropic 兼容协议访问 GLM/Kimi/DeepSeek 等国产模型
# ANTHROPIC_BASE_URL=http://your-gateway-host/public/

# 可选: 模型选择(默认 claude-sonnet-4-6)
# 使用兼容协议代理时,改为代理支持的模型名,例如:
# ANTHROPIC_MODEL=glm-4.7
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 可选: 代理设置(用于访问需要科学上网的数据源如 HuggingFace)
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
